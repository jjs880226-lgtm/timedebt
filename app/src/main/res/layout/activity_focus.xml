<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_focus_screen"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:letterSpacing="0.08"
        android:text="집중 모드"
        android:textColor="#94A3B8"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/focusTaskNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="할 일"
        android:textColor="#F8FAFC"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/focusTaskMetaText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="60분 · 패널티 +10%"
        android:textColor="#CBD5E1"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/focusTimerText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:text="25:00"
        android:textColor="#FFFFFF"
        android:textSize="72sp"
        android:textStyle="bold" />

    <ProgressBar
        android:id="@+id/focusSessionProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="24dp"
        android:max="100"
        android:progress="0"
        android:progressBackgroundTint="#334155"
        android:progressTint="#22C55E" />

    <TextView
        android:id="@+id/focusWarningText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_focus_chip"
        android:gravity="center"
        android:padding="12dp"
        android:text="앱 이탈 경고: 0/3"
        android:textColor="#FDE68A"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/focusEncourageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="지금은 이 화면만 보세요. 타이머가 끝나면 빚이 줄어듭니다."
        android:textColor="#94A3B8"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_weight="1"
        android:background="@drawable/bg_focus_chip"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/focusAiChatText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            android:text="AI: 집중 중 궁금한 것을 물어보세요."
            android:textColor="#E2E8F0"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/focusAiQuestionInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input"
            android:hint="AI에게 질문하기"
            android:imeOptions="actionSend"
            android:inputType="text|textCapSentences"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="#182230"
            android:textColorHint="#64748B"
            android:textSize="14sp" />

        <Button
            android:id="@+id/focusSendAiButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#7C3AED"
            android:text="AI에게 보내기"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/focusPauseButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#F59E0B"
        android:text="일시정지"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <Button
        android:id="@+id/focusExitButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#475569"
        android:text="집중 모드 나가기"
        android:textColor="#FFFFFF" />
</LinearLayout>
