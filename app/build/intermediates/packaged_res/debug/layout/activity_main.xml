<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="time debt"
            android:textColor="#182230"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="미룬 시간은 빚이 됩니다"
            android:textColor="#667085"
            android:textSize="15sp" />

        <LinearLayout
            android:id="@+id/debtCardContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_debt_card_safe"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="현재 시간 빚"
                    android:textColor="#FFF3E8"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/debtRiskBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_focus_chip"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="안전"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/debtText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="0시간 0분"
                android:textColor="#FFFFFF"
                android:textSize="42sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/todayDueText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="오늘 갚아야 할 시간: 0분"
                android:textColor="#FFF3E8"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/pointText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="보유 포인트: 0P"
                android:textColor="#FFF3E8"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/debtProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="16dp"
                android:max="480"
                android:progress="0"
                android:progressBackgroundTint="#33FFFFFF"
                android:progressTint="#FFD166" />

            <TextView
                android:id="@+id/debtRiskDetailText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="빚 위험도 0% · 파산까지 8시간 0분"
                android:textColor="#FFF3E8"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="스트릭 &amp; 업적"
                android:textColor="#182230"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/streakText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="🔥 연속 0일 · 최고 0일"
                android:textColor="#B54708"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/achievementText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="4dp"
                android:text="업적을 확인하세요."
                android:textColor="#475467"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_status"
            android:padding="14dp"
            android:text="할 일을 등록하면 시간 빚이 생성됩니다."
            android:textColor="#7A271A"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="할 일 추가"
                android:textColor="#182230"
                android:textSize="21sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/taskNameInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_input"
                android:hint="예: 알고리즘 과제"
                android:imeOptions="actionNext"
                android:inputType="text|textCapSentences"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#182230"
                android:textColorHint="#98A2B3" />

            <EditText
                android:id="@+id/taskMinutesInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="기본 시간(분)"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#182230"
                android:textColorHint="#98A2B3" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="미완료 패널티"
                android:textColor="#475467"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/penaltySpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <Button
                android:id="@+id/addTaskButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#2F6BFF"
                android:text="시간 빚 생성"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/taskListText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="등록된 할 일이 없습니다."
                android:textColor="#475467"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/focusPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="집중 모드"
                android:textColor="#182230"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="갚을 할 일 선택"
                android:textColor="#475467"
                android:textSize="14sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/taskSelectSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <TextView
                android:id="@+id/currentTaskText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="대기 중인 할 일이 없습니다."
                android:textColor="#475467"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/warningText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="앱 이탈 경고: 0/3"
                android:textColor="#B54708"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/timerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="00:00"
                android:textColor="#182230"
                android:textSize="44sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/focusProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginTop="8dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#12B76A" />

            <Button
                android:id="@+id/startFocusButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#12B76A"
                android:text="집중 화면으로 시작"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <Button
                android:id="@+id/stopFocusButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#F79009"
                android:enabled="false"
                android:text="일시정지"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aiChatText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_status"
                android:padding="14dp"
                android:text="AI: 집중 중 궁금한 것을 물어보세요. 예) 뭐부터 할까?, 쉬어도 돼?, 남은 시간 어때?"
                android:textColor="#7A271A"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/aiQuestionInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="AI에게 질문하기"
                android:imeOptions="actionSend"
                android:inputType="text|textCapSentences"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#182230"
                android:textColorHint="#98A2B3" />

            <Button
                android:id="@+id/sendAiQuestionButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#7A5AF8"
                android:text="AI에게 보내기"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="상점"
                android:textColor="#182230"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="집중 성공 시 60분당 5P를 받습니다."
                android:textColor="#475467"
                android:textSize="14sp" />

            <Button
                android:id="@+id/shopToggleButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="12dp"
                android:backgroundTint="#2F6BFF"
                android:text="상점 열기"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/shopItemsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"
                android:visibility="gone">

                <Button
                    android:id="@+id/buyMealButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#2F6BFF"
                    android:text="🍚 밥먹기 구매 - 10P"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/buyAirButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#0BA5EC"
                    android:text="🌿 잠깐 바람쐬러 나가기 - 5P"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/buySleepButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#7A5AF8"
                    android:text="😴 잠자기 구매 - 25P"
                    android:textColor="#FFFFFF" />

                <Button
                    android:id="@+id/buyRestButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="#12B76A"
                    android:text="☕ 1시간 쉬기 구매 - 10P"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:elevation="4dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="통계 및 분석"
                android:textColor="#182230"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="성공 0회 · 실패 0회 · 성공률 0%"
                android:textColor="#475467"
                android:textSize="16sp" />

            <Button
                android:id="@+id/bankruptcyButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="14dp"
                android:backgroundTint="#344054"
                android:text="파산하고 초기화"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
